# ── Required ─────────────────────────────────────────────────────────────
# Path to your Obsidian genome vault
GENOME_VAULT_ROOT=~/genome-vault

# Path to genome.db SQLite database (usually inside the vault)
GENOME_DB_PATH=~/genome-vault/data/genome.db

# ── Optional ─────────────────────────────────────────────────────────────
# Data directory for users.db and cache
GENOME_DATA_DIR=./data

# Anthropic API key for AI chat features
# ANTHROPIC_API_KEY=sk-ant-...

# HuggingFace token for GWAS data downloads (higher rate limits)
# Get one at https://huggingface.co/settings/tokens
# HF_TOKEN=hf_...

# ── TTS (text-to-speech) ─────────────────────────────────────────────────
# Provider override (default: auto-detect from available keys)
# TTS_PROVIDER=orpheus  # orpheus | elevenlabs | deepgram | browser | none

# Groq API key for Orpheus TTS
# GROQ_API_KEY=gsk_...

# ElevenLabs API key (optional, alternative TTS)
# ELEVENLABS_API_KEY=sk_...

# Deepgram API key (optional, alternative TTS)
# DEEPGRAM_API_KEY=...

# CORS origins (comma-separated, default: http://localhost:5173)
# CORS_ORIGINS=http://localhost:5173,http://localhost:3000
